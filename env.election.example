# Election contract target
CCD_ELECTION_CONTRACT_ADDRESS=<10087,0>
CCD_ELECTION_NETWORK=mainnet
CCD_ELECTION_NODE_ENDPOINT=https://grpc.mainnet.concordium.software:20000

# HTTP server
CCD_ELECTION_HTTP_PORT=8080
CCD_ELECTION_ALLOW_CORS=false

# Postgres
CCD_ELECTION_POSTGRES_DB=gc-election
CCD_ELECTION_POSTGRES_USER=postgres
CCD_ELECTION_POSTGRES_PASSWORD=password
CCD_ELECTION_POSTGRES_PORT=5432

# Optional tuning
CCD_ELECTION_LOG_LEVEL=info
CCD_ELECTION_DB_POOL_SIZE=16
CCD_ELECTION_MAX_BEHIND_SECONDS=240
CCD_ELECTION_REQUEST_TIMEOUT_MS=10000
